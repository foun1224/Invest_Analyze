{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/chipflow/handoff.schema.json",
  "title": "Taiwan Equity Chip-Flow AI Handoff",
  "type": "object",
  "required": [
    "schema_version", "report_type", "as_of_date", "analysis_window",
    "conventions", "field_legend", "labels", "series",
    "signals", "thesis", "key_levels"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "report_type": { "type": "string", "const": "taiwan_equity_chip_flow_analysis" },
    "purpose": { "type": "string" },
    "as_of_date": { "type": "string", "format": "date" },
    "generated_at": { "type": "string" },
    "language": { "type": "string" },
    "market_scope": { "type": "string" },
    "analysis_window": {
      "type": "object",
      "required": ["start", "end", "trading_days"],
      "properties": {
        "start": { "type": "string", "format": "date" },
        "end": { "type": "string", "format": "date" },
        "trading_days": { "type": "integer", "minimum": 1 }
      }
    },
    "conventions": {
      "type": "object",
      "description": "單位與正負號慣例。消費端必須遵守。",
      "required": ["amount_unit_default", "net_buy_sell_sign", "series_alignment"],
      "additionalProperties": { "type": "string" }
    },
    "data_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "use"],
        "properties": { "name": {"type":"string"}, "use": {"type":"string"} }
      }
    },
    "field_legend": {
      "type": "object",
      "description": "每個 series 欄位的定義。key 必須與 series 的 key 對應。",
      "additionalProperties": { "type": "string" }
    },
    "labels": {
      "type": "array",
      "description": "台股交易日主軸 MM/DD。所有 series 等長對齊此陣列。",
      "items": { "type": "string", "pattern": "^[0-9]{2}/[0-9]{2}$" },
      "minItems": 1
    },
    "series": {
      "type": "object",
      "description": "對齊後的時間序列;每條長度須等於 labels 長度;缺值為 null。",
      "additionalProperties": {
        "type": "array",
        "items": { "type": ["number", "null"] }
      }
    },
    "latest_snapshot_2026_06_30": { "type": "object" },
    "summary_stats": { "type": "object" },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["indicator", "reading", "direction", "rationale"],
        "properties": {
          "indicator": { "type": "string" },
          "reading": { "type": "string" },
          "direction": {
            "type": "string",
            "enum": ["bullish", "bearish", "neutral", "neutral_bullish", "neutral_bearish"]
          },
          "rationale": { "type": "string" }
        }
      }
    },
    "thesis": {
      "type": "object",
      "required": ["regime", "bull_case", "bear_case", "net_read"],
      "properties": {
        "regime": { "type": "string" },
        "core_insight": { "type": "string" },
        "bull_case": { "type": "string" },
        "bear_case": { "type": "string" },
        "net_read": { "type": "string" }
      }
    },
    "key_levels": {
      "type": "object",
      "required": ["range_low", "range_high"],
      "properties": {
        "range_low": { "type": "number" },
        "range_high": { "type": "number" },
        "supports": { "type": "array", "items": { "type": "number" } },
        "resistances": { "type": "array", "items": { "type": "number" } },
        "notes": { "type": "string" }
      }
    },
    "watch_list": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signal"],
        "properties": {
          "signal": { "type": "string" },
          "bullish": { "type": "string" },
          "bearish": { "type": "string" },
          "priority": { "type": "string" }
        }
      }
    },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "data_gaps_todo": { "type": "array", "items": { "type": "string" } },
    "data_gaps": {
      "type": "array",
      "description": "本次執行中抓取失敗、以 null 呈現的維度。禁止以假值填補。",
      "items": { "type": "string" }
    },
    "composition_2026_06_30": { "type": "object" }
  }
}
